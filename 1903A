#include<bits/stdc++.h>
using namespace std;
 
int main()
{
    int T;
    cin>>T;
    while(T--)
    {
        int n,k;
        cin>>n>>k;
        int a[n];
        for(auto &x:a)
        {
            cin>>x;
        }
        int f=0;
        for(int i=0;i<n-1;i++)
        {
            if(a[i]>a[i+1])
            {
            f=1;
            break;
            }
        }
        if(f==0||k>1)
        cout<<"Yes"<<endl;
        else
        cout<<"No"<<endl;
    }
}
